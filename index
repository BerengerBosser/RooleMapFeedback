<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Candidature APM · Roole Map</title>
<link rel="icon" type="image/png" href="https://play-lh.googleusercontent.com/3sPPeGJ3NVFakEEVZWsMLyMGmDArPElcGFafQqeyMLQ23YsjKYnx0DmdAe-CWCAiUg=w240-h480-rw">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{
--y:#ffd022;--b:#000001;--w:#ffffff;--g:#f5f5f7;--gt:#86868b;--black:#000001;--yellow:#ffd022;
--sans:'Inter',system-ui,sans-serif;--head:'Space Grotesk',sans-serif;
--ease:cubic-bezier(.22,1,.36,1);
}
html{scroll-behavior:smooth;overflow-x:hidden}
body{font-family:var(--sans);color:var(--b);background:var(--w);overflow-x:hidden;-webkit-font-smoothing:antialiased}
body.locked{overflow:hidden}
a{text-decoration:none;color:inherit}img{display:block;max-width:100%}ul{list-style:none}
::selection{background:var(--y);color:var(--b)}

/* ========== CUSTOM CURSOR ========== */
.cursor{position:fixed;width:18px;height:18px;border:2px solid var(--b);border-radius:50%;pointer-events:none;z-index:99999;
  transform:translate(-50%,-50%);transition:width .25s,height .25s,border-color .25s,background .25s;
  background: rgba(0,0,0,0.05)}
.cursor.hover{width:50px;height:50px;background:rgba(255,208,34,.25);border-color:var(--y)}
@media(pointer:coarse){.cursor{display:none}}

/* ============ INTRO ============ */
#intro{position:fixed;inset:0;z-index:100000;display:flex;align-items:center;justify-content:center;pointer-events:all;
background:var(--b);transition:background 1s ease}
#intro.light{background:var(--w)}
.intro-line{position:absolute;left:0;width:100%;background: #ffffff ;transform-origin:center;will-change:transform}
.intro-line{height:50vh;transform:scaleY(.04)}
.intro-line:nth-child(5){top:20vh}
.intro-line:nth-child(odd){transform:translateX(-110%) scaleY(.04)}
.intro-line:nth-child(even){transform:translateX(110%) scaleY(.04)}
.intro-line.slide{transform:translateX(0) scaleY(.04);transition:transform .55s cubic-bezier(.77,0,.175,1)}
.intro-line.expand{transform:translateX(0) scaleY(2.08);transition:transform .45s cubic-bezier(.77,0,.175,1)}

.intro-brand{position:relative;z-index:2;text-align:center;opacity:0;transform:translateY(15px);transition:opacity .5s,transform 1s}
.intro-brand.show{opacity:1;transform:translateY(0)}
.intro-brand h1{font-family:var(--head);font-size:clamp(42px,8vw,88px);font-weight:800;color:var(--y);letter-spacing:-2px}
.intro-brand p{color:rgb(0, 0, 0);font-size:clamp(14px,2vw,20px);margin-top:16px;font-weight:300}

#intro.reveal{transform:translateY(-100vh);transition:transform .75s cubic-bezier(.77,0,.175,1)}

/* ============ NAV ============ */
#nav{position:fixed;top:0;left:0;width:98%;z-index:9999;padding:18px 40px;display:flex;align-items:center;justify-content:space-between; border-radius: 30px; margin: 10px; margin-top: 20px;
transform:translateY(-100%);transition:transform .5s var(--ease),background .4s,backdrop-filter .4s,padding .3s }
#nav.visible{transform:translateY(0)}
#nav.vis{transform:translateY(0)}
#nav.scrolled{background:rgba(255, 253, 251, 0.656);backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(32px);padding:12px 40px;box-shadow:0 1px 0 rgba(0,0,0,.06); }
.nav-logo img{height:24px}
.nav-links{display:flex;gap:4px}
.nav-links a{color:var(--b);font-size:13px;font-weight:500;padding:8px 16px;border-radius:99px;transition:color .3s,background .3s}
.nav-links a:hover,.nav-links a.active{color:var(--b);background:var(--y)}
.nav-pill{display:flex;align-items:center;gap:8px;font-size:11px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:var(--gt)}
.nav-pill .dot{width:7px;height:7px;border-radius:50%;background:#34c759;animation:blink 2s infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}
.burger{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:4px}
.burger span{width:22px;height:2px;background:var(--b);border-radius:2px;transition:.3s}
.burger.open span:nth-child(1){transform:translateY(7px) rotate(45deg)}
.burger.open span:nth-child(2){opacity:0}
.burger.open span:nth-child(3){transform:translateY(-7px) rotate(-45deg)}
.mob-menu{position:fixed;inset:0;background:rgba(255,255,255,.97);backdrop-filter:blur(40px);z-index:9998;
display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px;
opacity:0;pointer-events:none;transition:opacity .35s}
.mob-menu.open{opacity:1;pointer-events:all}
.mob-menu a{font-family:var(--head);font-size:24px;font-weight:700;padding:12px 28px;border-radius:16px;transition:background .2s}
.mob-menu a:hover{background:var(--y)}

/* ============ HERO ============ */
#hero{position:relative;min-height:100vh;overflow:hidden;display:flex;align-items:flex-end}
.hero-bg{position:absolute;inset:0}
.hero-bg img{width:100%;height:100%;object-fit:cover;transform:scale(1.06);transition:transform 6s var(--ease)}
.hero-bg.loaded img{transform:scale(1)}
.hero-bg::after{content:'';position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,.88) 0%,rgba(0,0,0,.35) 45%,rgba(0,0,0,.12) 100%)}
.hero-content{position:relative;z-index:2;padding:0 60px 80px;width:100%}
.hero-tag{display:inline-flex;align-items:center;gap:8px;background:rgba(255,208,34,.15);border:1px solid rgba(255,208,34,.3);
padding:8px 20px;border-radius:99px;font-size:12px;font-weight:600;color:var(--y);letter-spacing:1.5px;text-transform:uppercase;
margin-bottom:24px;backdrop-filter:blur(8px)}
.hero-title{font-family:var(--head);font-size:clamp(38px,7vw,88px);font-weight:700;color:var(--w);line-height:1.02;letter-spacing:-3px}
.hero-title .line{display:block;overflow:hidden}
.hero-title .line span{display:inline-block;transform:translateY(110%);transition:transform .9s var(--ease)}
.hero-title.show .line span{transform:translateY(0)}
.hero-title .line:nth-child(2) span{transition-delay:.1s}
.hero-title .accent{color:var(--y)}
.hero-sub{color:rgba(255,255,255,.5);font-size:clamp(15px,1.6vw,19px);margin-top:20px;max-width:500px;line-height:1.6;
transform:translateY(24px);opacity:0;transition:all .8s var(--ease) .4s}
.hero-sub.show{transform:translateY(0);opacity:1}
.hero-cta{margin-top:28px;display:flex;gap:14px;flex-wrap:wrap;transform:translateY(24px);opacity:0;transition:all .8s var(--ease) .6s}
.hero-cta.show{transform:translateY(0);opacity:1}
.cta{display:inline-flex;align-items:center;gap:10px;padding:15px 30px;border-radius:99px;font-weight:600;font-size:15px;
cursor:pointer;border:none;transition:transform .3s,box-shadow .3s}
.cta-primary{background:var(--y);color:var(--b)}
.cta-primary:hover{transform:translateY(-2px);box-shadow:0 10px 36px rgba(255,208,34,.35)}
.cta-ghost{background:rgba(255,255,255,.1);color:var(--w);border:1px solid rgba(255,255,255,.18);backdrop-filter:blur(8px)}
.cta-ghost:hover{background:rgba(255,255,255,.18)}
.hero-scroll{position:absolute;bottom:28px;left:50%;transform:translateX(-50%);z-index:3;
display:flex;flex-direction:column;align-items:center;gap:6px;color:rgba(255,255,255,.35);
font-size:11px;letter-spacing:2px;text-transform:uppercase}
.hero-scroll .wheel{width:18px;height:28px;border:2px solid rgba(255,255,255,.25);border-radius:9px;position:relative}
.hero-scroll .wheel::after{content:'';position:absolute;top:5px;left:50%;transform:translateX(-50%);
width:2px;height:7px;background:var(--y);border-radius:2px;animation:wh 2s infinite}
@keyframes wh{0%{opacity:1;transform:translateX(-50%) translateY(0)}100%{opacity:0;transform:translateX(-50%) translateY(10px)}}

/* ============ ROAD DIVIDER ============ */
.road-divider{position:relative;height:80px;background:var(--b);overflow:hidden;z-index:10}
.road-surface{position:absolute;inset:0;display:flex;align-items:center}
.road-dashes{display:flex;gap:36px;animation:dashScroll 8s linear infinite;position:absolute;left:0}
.road-dashes span{width:50px;height:3px;background:linear-gradient(90deg, var(--y), rgba(255,208,34,0.7));border-radius:2px;flex-shrink:0;opacity:.5;
box-shadow: 0 0 6px rgba(255,208,34,0.4)}
@keyframes dashScroll{100%{transform:translateX(0)}0%{transform:translateX(-86px)}}
.road-car-img{position:absolute;height:48px;animation:carCruise 12s linear infinite, carGlow 1.5s ease-in-out infinite alternate;top:50%;transform:translateY(-68%);
filter: drop-shadow(0 0 8px rgba(255,208,34,0.6)) brightness(1.1); will-change: filter}
.road-car-img::before{content:'';position:absolute;left:-80px;top:50%;width:80px;height:2px;background:linear-gradient(to right, rgba(255,208,34,0.8), transparent);
transform:translateY(-50%);opacity:0.7;animation:trailFade 0.5s infinite}
@keyframes carGlow { 0% { filter: drop-shadow(0 0 8px rgba(255,208,34,0.6)) brightness(1.1) } 100% { filter: drop-shadow(0 0 16px rgba(255,208,34,0.9)) brightness(1.3) } }
@keyframes trailFade { 0% { opacity: 0.7 } 100% { opacity: 0 } }
@keyframes carCruise{100%{left:-180px}0%{left:calc(100% + 180px)}}

/* ============ SECTIONS ============ */
.sec{position:relative;overflow:hidden}
.container{max-width:1200px;margin:0 auto;padding:0 40px}
.pad{padding:120px 0}
[data-r]{opacity:0;transform:translateY(40px);transition:opacity .7s var(--ease),transform .7s var(--ease)}
[data-r].vis{opacity:1;transform:translateY(0)}
[data-r][data-d="1"]{transition-delay:.1s}[data-r][data-d="2"]{transition-delay:.2s}[data-r][data-d="3"]{transition-delay:.3s}
[data-r][data-d="4"]{transition-delay:.4s}
.badge{display:inline-flex;align-items:center;gap:6px;font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:2px;
padding:8px 18px;border-radius:99px;margin-bottom:20px}
.badge-y{background:var(--y);color:var(--b)}
.badge-dark{background:var(--b);color:var(--y)}
.sec-title{font-family:var(--head);font-size:clamp(30px,4.5vw,58px);font-weight:700;line-height:1.08;letter-spacing:-2px;margin-bottom:18px}
.sec-sub{font-size:clamp(15px,1.5vw,18px);line-height:1.65;color:var(--gt);max-width:540px}

/* ============ ENTREPRISE ============ */
#entreprise{background:var(--w); position:relative; overflow:hidden}
#entreprise::before{content:'';position:absolute;inset:0;background:url('https://assets.prod.roole.fr/data/assets/hero_product_a4fc12d46b.png') center/cover no-repeat;opacity:0.15}

.ent-grid{display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center;margin-bottom:64px}
.ent-grid img{border-radius:24px;width:100%;object-fit:cover}
.stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-top:32px}
.stat{background:var(--g);border-radius:20px;padding:14px;text-align:center;transition:transform .3s}
.stat:hover{transform:translateY(-4px)}
.stat .num{font-family:var(--head);font-size:36px;font-weight:700}
.stat .accent{color:var(--y)}
.stat .lbl{font-size:13px;color:var(--gt);margin-top:2px}
.product-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:20px;margin-top:48px}
.p-card{background:var(--g);border-radius:24px;padding:32px;position:relative;overflow:hidden;
transition:transform .4s var(--ease),box-shadow .4s;cursor:default;border:2px solid transparent}
.p-card:hover{transform:translateY(-6px);box-shadow:0 16px 48px rgba(0,0,0,.06);border-color:var(--y)}
.p-card .glow{position:absolute;top:-60px;right:-60px;width:160px;height:160px;
background:radial-gradient(circle,rgba(255,208,34,.15),transparent 70%);opacity:0;transition:opacity .4s}
.p-card:hover .glow{opacity:1}
.p-card img{width:52px;height:52px;border-radius:14px;margin-bottom:16px;object-fit:cover}
.p-card .p-tag{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;color:var(--y);margin-bottom:8px}
.p-card h4{font-family:var(--head);font-size:19px;font-weight:700;margin-bottom:8px}
.p-card p{color:var(--gt);font-size:13.5px;line-height:1.6}
.p-card.feat{border-color:var(--y);background:rgba(255,208,34,.04)}
.p-card.feat::after{content:'LE POSTE';position:absolute;top:14px;right:14px;background:var(--y);color:var(--b);
font-size:9px;font-weight:800;padding:4px 10px;border-radius:99px;letter-spacing:1px}

/* ============ VISION CARDS ============ */
.vision-card{background:var(--w);border-radius:20px;padding:32px;text-align:center;border:1px solid rgba(0,0,0,.04);
transition:transform .3s var(--ease),box-shadow .3s}
.vision-card:hover{transform:translateY(-4px);box-shadow:0 12px 32px rgba(0,0,0,.08)}
.vision-icon{width:60px;height:60px;background:var(--y);border-radius:18px;display:flex;align-items:center;justify-content:center;
font-size:24px;color:var(--b);margin:0 auto 20px}
.vision-card h4{font-family:var(--head);font-size:18px;font-weight:700;margin-bottom:12px}
.vision-card p{color:var(--gt);font-size:14px;line-height:1.6}

/* ============ IMAGE BREAK ============ */
.img-break{position:relative;height:50vh;min-height:300px;overflow:hidden}
.img-break img{width:100%;height:120%;object-fit:cover;filter:brightness(.45)}
.img-break .ib-txt{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;
flex-direction:column;text-align:center;z-index:2;padding:0 24px;color:var(--w)}
.img-break .ib-txt h2{font-family:var(--head);font-size:clamp(26px,4.5vw,48px);font-weight:700;letter-spacing:-1px;margin-bottom:8px}
.img-break .ib-txt p{color:rgba(255,255,255,.55);font-size:17px}

/* ============ POSTE ============ */
#poste{background:var(--g)}
.tabs-bar{display:flex;gap:8px;margin-bottom:36px;flex-wrap:wrap}
.tab-btn{padding:10px 22px;border-radius:99px;border:2px solid rgba(0,0,0,.08);background:var(--w);font-size:13px;
font-weight:600;cursor:pointer;transition:all .25s}
.tab-btn.active{background:var(--b);color:var(--w);border-color:var(--b)}
.tab-panel{display:none;animation:fadeIn .4s ease}
.tab-panel.active{display:block}
@keyframes fadeIn{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}
.mission-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:14px}
.m-item{display:flex;gap:14px;align-items:flex-start;background:var(--w);padding:22px;border-radius:18px;
border:1px solid transparent;transition:border-color .3s,transform .3s}
.m-item:hover{border-color:var(--y);transform:translateY(-2px)}
.m-icon{flex-shrink:0;width:40px;height:40px;background:var(--y);border-radius:12px;
display:flex;align-items:center;justify-content:center;font-size:15px;color:var(--b)}
.m-item h5{font-size:14px;font-weight:700;margin-bottom:3px}
.m-item p{font-size:13px;color:var(--gt);line-height:1.5}
.team-cols{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-top:32px}
.t-box{background:var(--w);border-radius:24px;padding:32px;transition:transform .3s}
.t-box:hover{transform:translateY(-4px)}
.t-box h4{font-family:var(--head);font-size:17px;font-weight:700;margin-bottom:14px;display:flex;align-items:center;gap:8px}
.t-box h4 i{color:var(--y)}
.t-box ul li{display:flex;align-items:center;gap:10px;padding:7px 0;font-size:14px;border-bottom:1px solid var(--g)}
.t-box ul li:last-child{border:none}
.t-box ul li i{color:var(--y);width:16px;text-align:center;font-size:12px}
.t-box.me{border:2px solid var(--y)}
.t-box.me::before{content:'🎯 Mon équipe';position:absolute;top:14px;right:14px;background:var(--y);color:var(--b);
font-size:10px;font-weight:800;padding:4px 12px;border-radius:99px}
.t-box{position:relative}
.sprint-pill{display:inline-flex;align-items:center;gap:6px;margin-top:14px;padding:8px 14px;border-radius:99px;
background:rgba(255,208,34,.1);font-size:12px;font-weight:600}
.role-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px;margin-top:28px}
.role-item{background:var(--w);border-radius:18px;padding:24px;text-align:center;transition:transform .3s}
.role-item:hover{transform:translateY(-4px)}
.role-item i{font-size:26px;color:var(--y);margin-bottom:12px}
.role-item h5{font-family:var(--head);font-size:15px;font-weight:700;margin-bottom:6px}
.role-item p{font-size:12px;color:var(--gt);line-height:1.5}

/* ============ MOTIVATIONS ============ */
#motivations{background:var(--w)}
.mot-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(340px,1fr));gap:24px;margin-top:48px}
.mot-card{background:var(--g);border-radius:24px;padding:36px;position:relative;overflow:hidden;transition:transform .4s var(--ease)}
.mot-card:hover{transform:translateY(-5px)}
.mot-card .mot-num{font-family:var(--head);font-size:72px;font-weight:700;color:rgba(0,0,0,.04);position:absolute;top:-6px;right:14px;line-height:1}
.mot-card .mot-icon{width:48px;height:48px;background:var(--y);border-radius:14px;display:flex;align-items:center;
justify-content:center;font-size:20px;color:var(--b);margin-bottom:18px}
.mot-card h4{font-family:var(--head);font-size:19px;font-weight:700;margin-bottom:8px}
.mot-card p{color:var(--gt);font-size:14px;line-height:1.65}
.mot-card .tags{display:flex;flex-wrap:wrap;gap:6px;margin-top:12px}
.mot-card .tags span{background:var(--w);padding:5px 12px;border-radius:99px;font-size:11px;font-weight:600}
.cta-banner{background:var(--b);border-radius:28px;padding:52px;display:flex;align-items:center;justify-content:space-between;
gap:40px;margin-top:64px;position:relative;overflow:hidden}
.cta-banner::before{content:'';position:absolute;top:-50px;right:-50px;width:200px;height:200px;
background:radial-gradient(circle,rgba(255,208,34,.15),transparent 70%)}
.cta-banner h3{font-family:var(--head);font-size:clamp(20px,3vw,34px);font-weight:700;color:var(--w);line-height:1.15;flex:1;letter-spacing:-1px}
.cta-banner h3 span{display:block;font-size:clamp(13px,1.3vw,16px);font-weight:400;color:rgba(255,255,255,.45);margin-top:8px}
.cta-banner .cta{background:var(--y);color:var(--b);flex-shrink:0}

/* ============ PARCOURS ============ */
#parcours{background:var(--g)}
.timeline{position:relative;max-width:860px;margin:48px auto 0}
.tl-line{position:absolute;left:40px;top:0;width:3px;height:100%;background:linear-gradient(to bottom,var(--y),rgba(255, 202, 96, 0.15));border-radius:3px}
.tl-item{position:relative;padding-left:92px;padding-bottom:44px}
.tl-item:last-child{padding-bottom:0}
.tl-dot{position:absolute;left:31px;top:8px;width:22px;height:22px;border:4px solid var(--y);background:var(--w);
border-radius:50%;z-index:2;transition:transform .3s,background .3s,box-shadow .3s}
.tl-item:hover .tl-dot{transform:scale(1.35);background:var(--y);box-shadow:0 0 16px rgba(255,208,34,.35)}
.tl-date{font-family:var(--head);font-size:12px;font-weight:700;color:var(--b);letter-spacing:.8px;margin-bottom:6px;opacity:.45}
.tl-card{background:var(--w);border-radius:20px;padding:28px;border:1px solid rgba(0,0,0,.04);
transition:transform .35s var(--ease),box-shadow .35s}
.tl-card:hover{transform:translateX(6px);box-shadow:0 10px 40px rgba(0,0,0,.06)}
.tl-card h3{font-family:var(--head);font-size:17px;font-weight:700}
.tl-card .tl-co{font-size:13px;font-weight:700;margin:2px 0 6px;display:flex;align-items:center;gap:6px}
.tl-card .tl-co i{color:var(--y)}
.tl-card .tl-type{display:inline-block;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.8px;
padding:4px 10px;border-radius:99px;background:var(--g);color:var(--gt);margin-bottom:10px}
.tl-card ul li{font-size:13px;color:var(--gt);line-height:1.5;padding:3px 0 3px 16px;position:relative}
.tl-card ul li::before{content:'›';position:absolute;left:0;color:var(--y);font-weight:700;font-size:15px}

/* Skills */
.skills-wrap{margin-top:72px}
.skills-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:20px;margin-top:32px}
.sk-grp{background:var(--w);border-radius:20px;padding:28px}
.sk-grp h4{font-family:var(--head);font-size:15px;font-weight:700;margin-bottom:16px;display:flex;align-items:center;gap:8px}
.sk-grp h4 i{color:var(--y)}
.sk-bar{margin-bottom:14px}
.sk-bar:last-child{margin-bottom:0}
