<script>
/* ============ INTRO ANIMATION ============ */
(function(){
  const intro = document.getElementById('intro');
  const lines = intro.querySelectorAll('.intro-line');
  const brand = intro.querySelector('.intro-brand');
  const header = document.getElementById('nav');

  // Step 1: Slide lines in
  lines.forEach((l, i) => {
    setTimeout(() => l.classList.add('slide'),300 + i * 90);
  });

  // Step 2: Expand lines
  setTimeout(() => {
    lines.forEach(l => l.classList.add('expand'));    intro.classList.add('light');  }, 700 + lines.length * 90 + 250);

  // Step 3: Show brand
  setTimeout(() => {
    brand.classList.add('show');
  }, 350 + lines.length * 90 + 700);

  // Step 4: Reveal page
  setTimeout(() => {
    intro.classList.add('reveal');
    document.body.classList.remove('locked');
    header.classList.add('visible');
    initHero();
  }, 350 + lines.length * 90 + 2100);

  // Step 5: Cleanup
  setTimeout(() => {
    intro.remove();
  }, 350 + lines.length * 90 + 2900);
})();

function initHero(){
  document.getElementById('heroBg').classList.add('loaded');
  setTimeout(()=>document.getElementById('heroTitle').classList.add('show'),100);
  setTimeout(()=>document.getElementById('heroSub').classList.add('show'),100);
  setTimeout(()=>document.getElementById('heroCta').classList.add('show'),100);
}

/* Scroll to top on page load */
window.addEventListener('load',()=>window.scrollTo(0,0));
if(document.readyState==='loading'){document.addEventListener('DOMContentLoaded',()=>window.scrollTo(0,0))}else{window.scrollTo(0,0);}

/* ========== CUSTOM CURSOR ========== */
(function(){
  const cur = document.getElementById('cursor');
  if(window.matchMedia('(pointer:coarse)').matches) return;
  document.addEventListener('mousemove', e => {
    cur.style.left = e.clientX + 'px';
    cur.style.top = e.clientY + 'px';
  });
  document.querySelectorAll('a, button, .cta, .p-card, .mot-card, .tl-card, .m-item, .t-box, .role-item').forEach(el => {
    el.addEventListener('mouseenter', () => cur.classList.add('hover'));
    el.addEventListener('mouseleave', () => cur.classList.remove('hover'));
  });
})();

/* ============ NAV SCROLL ============ */
/*
// Always scrolled
window.addEventListener('scroll',()=>{
  document.getElementById('nav').classList.toggle('scrolled',scrollY>60);
},{passive:true});
*/

// Active link
const allSecs=document.querySelectorAll('section[id]');
const navLinks=document.querySelectorAll('.nav-links a');
window.addEventListener('scroll',()=>{
  let c='';allSecs.forEach(s=>{if(scrollY>=s.offsetTop-200)c=s.id});
  navLinks.forEach(a=>a.classList.toggle('active',a.getAttribute('href')==='#'+c));
},{passive:true});

/* ============ BURGER ============ */
const burger=document.getElementById('burger'),mob=document.getElementById('mobMenu');
burger.addEventListener('click',()=>{burger.classList.toggle('open');mob.classList.toggle('open')});
mob.querySelectorAll('a').forEach(a=>a.addEventListener('click',()=>{burger.classList.remove('open');mob.classList.remove('open')}));

/* ============ SCROLL REVEAL ============ */
const rObs=new IntersectionObserver(es=>{es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('vis');rObs.unobserve(e.target)}})},{threshold:.1});
document.querySelectorAll('[data-r]').forEach(el=>rObs.observe(el));

/* ============ COUNTERS ============ */
const cObs=new IntersectionObserver(es=>{es.forEach(e=>{if(!e.isIntersecting)return;const el=e.target;const t=+el.dataset.target;const d=2800;const s=performance.now();
(function tick(now){const p=Math.min((now-s)/d,1);el.textContent=Math.round((1-Math.pow(1-p,3))*t);if(p<1)requestAnimationFrame(tick)})(s);cObs.unobserve(el)})},{threshold:.5});
document.querySelectorAll('.counter').forEach(c=>cObs.observe(c));

/* ============ SKILL BARS ============ */
const sObs=new IntersectionObserver(es=>{es.forEach(e=>{if(e.isIntersecting){e.target.style.width=e.target.dataset.w+'%';sObs.unobserve(e.target)}})},{threshold:.3});
document.querySelectorAll('.sk-fill').forEach(f=>sObs.observe(f));

/* ============ TABS ============ */
document.querySelectorAll('.tab-btn').forEach(b=>{b.addEventListener('click',()=>{
  document.querySelectorAll('.tab-btn').forEach(x=>x.classList.remove('active'));
  document.querySelectorAll('.tab-panel').forEach(x=>x.classList.remove('active'));
  b.classList.add('active');
  document.getElementById('tab-'+b.dataset.tab).classList.add('active');
  // Re-observe new reveals
  document.querySelectorAll('.tab-panel.active [data-r]:not(.vis)').forEach(el=>rObs.observe(el));
})});

/* ============ PARALLAX ============ */
window.addEventListener('scroll',()=>{
  document.querySelectorAll('.parallax-img').forEach(img=>{
    const r=img.parentElement.getBoundingClientRect();
    img.style.transform='translateY('+r.top*.18+'px)';
  });
},{passive:true});

/* ============ MAGNETIC SCROLL TO TOP ============ */
let lastScrollY=0;
window.addEventListener('scroll',()=>{
  const magnetZone=800;
  const currentScroll=scrollY;
  const scrollingUp=currentScroll<lastScrollY;
  if(scrollingUp&&currentScroll<magnetZone&&currentScroll>0){
    window.scrollTo({top:0,behavior:'smooth'});
  }
  lastScrollY=currentScroll;
},{passive:true});

/* ============ 3D TILT ON PRODUCT CARDS ============ */
if(!matchMedia('(pointer:coarse)').matches){
  document.querySelectorAll('.p-card').forEach(c=>{
    let tiltX=0,tiltY=0;
    c.style.transition='transform 0.1s ease-out';
    c.addEventListener('mousemove',e=>{
      const r=c.getBoundingClientRect();
      const x=(e.clientX-r.left)/r.width-.5;
      const y=(e.clientY-r.top)/r.height-.5;
      tiltX=y*15;tiltY=x*15;
      c.style.transform=`perspective(800px) rotateX(${tiltX}deg) rotateY(${tiltY}deg) translateZ(20px)`;
    });
    c.addEventListener('mouseleave',()=>{
      c.style.transform='perspective(800px) rotateX(0deg) rotateY(0deg) translateZ(0px)';
    });
    c.addEventListener('mouseenter',()=>{
      c.style.transition='transform 0.05s ease-out';
    });
  });
}

/* ============ 3D TILT ON TIMELINE CARDS ============ */
if(!matchMedia('(pointer:coarse)').matches){
  document.querySelectorAll('.tl-card').forEach(c=>{
    let tiltX=0,tiltY=0;
    c.style.transition='transform 0.1s ease-out';
    c.addEventListener('mousemove',e=>{
      const r=c.getBoundingClientRect();
      const x=(e.clientX-r.left)/r.width-.5;
      const y=(e.clientY-r.top)/r.height-.5;
      tiltX=y*5;tiltY=x*5;
      c.style.transform=`perspective(800px) rotateX(${tiltX}deg) rotateY(${tiltY}deg) translateZ(20px)`;
    });
    c.addEventListener('mouseleave',()=>{
      c.style.transform='perspective(800px) rotateX(0deg) rotateY(0deg) translateZ(0px)';
    });
    c.addEventListener('mouseenter',()=>{
      c.style.transition='transform 0.05s ease-out';
    });
  });
}
</script>
